<tal:r i18n:domain="bes.lims"
  define="report_id string:pathogen_by_sample_type">

  <h2 i18n:translate="">
    4.3 Number of pathogens by sample type
  </h2>

  <form method="post">

    <!-- Date control -->
    <div class="form-group form-inline">
      <tal:date replace="structure python:view.date_control()"/>
    </div>

    <!-- Submit button -->
    <input tabindex=""
           class="searchButton allowMultiSubmit"
           type="submit"
           name="submit"
           value="Generate report"
           i18n:attributes="value"/>

    <!-- hidden fields -->
    <input tal:replace="structure context/@@authenticator/authenticator"/>
    <input type="hidden" name="report_id" tal:attributes="value report_id"/>

  </form>

</tal:r>
